{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "predev": "npm run sanity:typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../frontend && sanity typegen generate",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@next/third-parties": "^15.5.12",
    "@portabletext/react": "^6.0.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@sanity/client": "^7.13.2",
    "@sanity/image-url": "^1.2.0",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.454.0",
    "next": "16.1.5",
    "next-sanity": "^12.0.5",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sanity": "^5.1.0",
    "sanity-image": "^1.0.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.1",
    "typescript": "5.9.3"
  }
}
